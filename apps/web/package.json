{
	"name": "@justsow/web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "pnpm run typecheck",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:setup": "playwright install chromium chromium-headless-shell",
		"test:unit": "vitest run --project server",
		"test:browser": "vitest run --project client",
		"test:browser:ci": "vitest run --project client",
		"test": "pnpm run test:unit && pnpm run test:browser:ci"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@iconify-json/simple-icons": "^1.2.89",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.23.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.69.2",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.0.0",
		"@types/node": "^26",
		"@vitest/browser": "^4.1.10",
		"@vitest/browser-playwright": "^4.1.10",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^17.7.0",
		"playwright": "^1.53.0",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.0.0",
		"svelte-check": "^4.7.2",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.0.0",
		"tw-animate-css": "^1.3.8",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.20.0",
		"unplugin-icons": "^23.0.1",
		"vite": "^8.1.3",
		"vitest": "^4.1.10",
		"vitest-browser-svelte": "^2.2.1"
	},
	"dependencies": {
		"@iconify-json/flagpack": "^1.2.8",
		"@iconify/svelte": "^5.2.2",
		"libphonenumber-js": "^1.13.8",
		"qrcode": "^1.5.4"
	}
}
